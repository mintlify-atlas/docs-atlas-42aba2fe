  "keyFeatures": [
    "Self-contained Triton paged attention kernel for decode phase",
    "Self-contained Triton flash attention kernel for prefill phase (O(N) memory)",
    "Prefix caching via content-aware KV cache block hashing",
    "Multi-GPU tensor parallelism with NCCL collective operations",
    "CUDA graph capture for low-latency decode",
    "Iteration-level scheduling with preemption support",
    "Grouped Query Attention (GQA) support",
    "Qwen3 and Llama 3.2 model implementations",
    "Comprehensive benchmark suite comparing PyTorch, Triton, and Flash Attention"
  ],
  "publicApiSurface": [
    "LLMEngine(config: dict)",
    "LLMEngine.generate(prompts: list[str], sampling_params: SamplingParams) -> dict",
    "LLMEngine.add_prompt(prompt: str, sampling_params: SamplingParams) -> None",
