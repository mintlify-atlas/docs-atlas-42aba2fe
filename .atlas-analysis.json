    "SamplingParams(temperature, max_tokens, ignore_eos, max_model_length)",
    "Scheduler(max_num_sequences, max_num_batched_tokens, max_cached_blocks, block_size, eos)",
    "ModelRunner(config, rank, event)",
    "Attention(num_heads, head_dim, scale, num_kv_heads, block_size)",
    "flash_attention_prefill(q, k, v, cu_seqlens, scale, num_heads, num_kv_heads, head_dim)",
    "paged_attention_decode(query, k_cache, v_cache, block_tables, context_lens, scale, ...)",
    "store_kvcache(key, value, k_cache, v_cache, slot_mapping, block_size)",
    "BlockManager(num_blocks, block_size)",
    "Sequence(token_ids, block_size, sampling_params)"
  ]
